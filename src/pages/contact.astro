---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Header } from "@/sections/Header";
import { HeroSection } from "@/pages/contact/sections/HeroSection";
import { FAQSection } from "@/pages/contact/sections/FAQSection";
import { Footer } from "@/sections/Footer";
import { CANONICAL_PHONE } from "@/utils/phoneTracking";
---

<BaseLayout 
  title="Contact Us - Glasgow Fencing Contractors | Get Your Free Quote Today"
  description={`Contact Glasgow Fencing Contractors for fencing and decking. Get a free quote today across Greater Glasgow. Call ${CANONICAL_PHONE} or use our contact form.`}
  canonical="https://www.glasgowfencingcontractors.co.uk/contact"
>
    <div class="text-neutral-600 text-lg not-italic normal-nums font-medium accent-auto bg-[#323232] box-border caret-transparent block tracking-[normal] leading-[27px] list-outside list-disc min-h-full pointer-events-auto text-start indent-[0px] normal-case visible border-separate font-manrope">
      <Header client:load />
      <HeroSection client:load />
      <FAQSection client:load />
      <Footer client:load />
    </div>
</BaseLayout>

