    { params: { slug: "fence-design-irvine" } },
    { params: { slug: "privacy-fence-installation-irvine" } },
    { params: { slug: "security-fencing-and-metal-cage-installation-irvine" } },
    { params: { slug: "deck-construction-irvine" } },
    { params: { slug: "patio-construction-irvine" } },
    { params: { slug: "deck-repair-irvine" } },
    { params: { slug: "deck-replacement-irvine" } },
    { params: { slug: "deck-design-irvine" } },
    { params: { slug: "patio-decks-irvine" } },
    { params: { slug: "cabin-design-and-building-irvine" } },
    { params: { slug: "custom-shed-design-irvine" } },
    { params: { slug: "storage-shed-design-and-building-irvine" } },
    { params: { slug: "landscape-installations-irvine" } },
    { params: { slug: "outdoor-step-construction-irvine" } },
    { params: { slug: "patio-design-irvine" } },
    { params: { slug: "repairs-and-maintenance-irvine" } },
