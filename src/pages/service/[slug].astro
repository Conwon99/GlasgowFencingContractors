// Generate meta description based on slug (optimized to 120-160 characters)
const getDescription = (slug: string | undefined) => {
  const descriptionMap: Record<string, string> = {
    "fencing": "Professional fence installation in Greater Glasgow & Glasgow. Expert contractors, 13+ years experience. Quality materials, free quotes, fully insured.",
    "fence-repairs": "Expert fence repair services in Greater Glasgow. Fast, reliable repairs for all fence types. Fully qualified contractors, free quotes, 13+ years experience.",
    "decking": "Professional decking installation in Greater Glasgow & Glasgow. High-quality timber and composite decking. Expert installation, free quotes, 13+ years experience.",
    "gates": "Gate installation services in Greater Glasgow. Garden gates, security gates, and custom solutions. Professional installation, quality materials, free quotes.",
    "sheds": "Custom shed building and installation in Greater Glasgow. Professional construction services. Quality materials, expert craftsmanship, free quotes available.",
    "garden-rooms": "Garden room installation in Greater Glasgow & Glasgow. Professional construction for versatile spaces. Expert installation, free quotes, 13+ years experience.",
