    "cabin-design-and-building-irvine": "Cabin design and building in Greater Glasgow. Custom cabin construction for various uses. Professional design and building, free quotes.",
    "custom-shed-design-irvine": "Custom shed design in Greater Glasgow. Professional shed design services. Tailored solutions, expert planning, free quotes.",
    "storage-shed-design-and-building-irvine": "Storage shed design and building in Greater Glasgow. Professional storage solutions. Custom design and construction, free quotes.",
    "landscape-installations-irvine": "Landscape installations in Greater Glasgow. Professional hard landscaping services. Paths, steps, planting areas, free quotes.",
    "outdoor-step-construction-irvine": "Outdoor step construction in Greater Glasgow. Professional step building services. Safe, durable construction, free quotes.",
    "patio-design-irvine": "Patio design services in Greater Glasgow. Professional patio design consultation. Custom solutions, expert planning, free quotes.",
    "repairs-and-maintenance-irvine": "Repairs and maintenance services in Greater Glasgow. Professional maintenance for outdoor structures. Regular upkeep, free quotes.",
  };
  return descriptionMap[slug || ""] || "Professional fencing and decking services in Greater Glasgow. Expert installation, quality materials, free quotes, 13+ years experience.";
};

const pageTitle = getTitle(slug);
const pageDescription = getDescription(slug);
const canonicalUrl = `https://www.glasgowfencingcontractors.co.uk/service/${slug}`;
const servicePageName = pageTitle.split("|")[0].trim();
const serviceSchema = buildServicePageJsonLd({
  name: servicePageName,
  description: pageDescription,
  url: canonicalUrl,
});

// Determine if we should show projects section and which category
const showProjects = slug === "fencing" || slug === "fence-repairs" || slug === "decking";
const projectCategory: "fencing" | "decking" = slug === "decking" ? "decking" : "fencing";
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonicalUrl} extraJsonLd={[serviceSchema]}>
    <div class="text-neutral-600 text-lg not-italic normal-nums font-medium accent-auto bg-[#323232] box-border caret-transparent block tracking-[normal] leading-[27px] list-outside list-disc min-h-full pointer-events-auto text-start indent-[0px] normal-case visible border-separate font-manrope">
      <Header client:load />
      <Hero slug={slug} client:only="react" />
      <ServiceDetail slug={slug} client:only="react" />
      {showProjects && <ServiceProjectsSection category={projectCategory} limit={3} client:only="react" />}
      <ReviewsSection client:load />
      <ServicesSection slug={slug} client:only="react" />
      <FAQ slug={slug} client:only="react" />
      <CTASection client:load />
      <Footer client:load />
    </div>
</BaseLayout>

