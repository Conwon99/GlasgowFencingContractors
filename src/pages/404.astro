---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Header } from "@/sections/Header";
import { Footer } from "@/sections/Footer";
import { CANONICAL_PHONE, CANONICAL_PHONE_TEL } from "@/utils/phoneTracking";
---

<BaseLayout
  title="Page not found | Glasgow Fencing Contractors"
  description="That page does not exist or has moved. Return home or contact Glasgow Fencing Contractors for fencing and decking in Greater Glasgow."
  canonical="https://www.glasgowfencingcontractors.co.uk/404"
  noindex={true}
>
  <div class="text-neutral-600 text-lg font-medium bg-[#323232] min-h-[70vh] font-manrope">
    <Header client:load />
    <main class="max-w-[720px] mx-auto px-[15px] py-[80px] md:py-[120px] text-center">
      <p class="text-[#8a9168] text-sm font-bold uppercase tracking-wide mb-4">404</p>
      <h1 class="text-white text-3xl md:text-5xl font-bold mb-6">Page not found</h1>
      <p class="text-gray-200 mb-10 leading-relaxed">
        The page you are looking for may have moved or no longer exists. Use the links below or call us and we will point you in the right direction.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-10">
        <a
          href="/"
          class="inline-flex items-center justify-center min-h-[48px] px-8 rounded-[100px] bg-[#787e59] text-white font-semibold hover:bg-[#8a9168] transition-colors w-full sm:w-auto"
        >
          Back to home
        </a>
        <a
          href="/services"
          class="inline-flex items-center justify-center min-h-[48px] px-8 rounded-[100px] border-2 border-white text-white font-semibold hover:bg-white/10 transition-colors w-full sm:w-auto"
        >
          View services
        </a>
      </div>
      <p class="text-gray-300 text-base">
        Or call us directly:{" "}
        <a href={`tel:${CANONICAL_PHONE_TEL}`} class="text-[#8a9168] font-semibold underline-offset-2 hover:underline">
          {CANONICAL_PHONE}
        </a>
      </p>
    </main>
    <Footer client:load />
  </div>
</BaseLayout>
