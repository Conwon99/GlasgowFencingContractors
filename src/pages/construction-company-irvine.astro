---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Header } from "@/sections/Header";
import { Hero } from "@/pages/services/sections/Hero";
import { ServicesSection } from "@/pages/services/sections/ServicesSection";
import { WhyChooseSection } from "@/pages/services/sections/WhyChooseSection";
import { FAQSection } from "@/pages/services/sections/FAQSection";
import { CTASection } from "@/sections/Footer/components/CTASection";
import { Footer } from "@/sections/Footer";
---

<BaseLayout title="Construction Company Ayrshire | Professional Builders | Ayrshire Fencing Group">
    <div class="text-neutral-600 text-lg not-italic normal-nums font-medium accent-auto bg-[#323232] box-border caret-transparent block tracking-[normal] leading-[27px] list-outside list-disc min-h-full pointer-events-auto text-start indent-[0px] normal-case visible border-separate font-manrope">
      <Header client:load />
      <Hero client:load />
      <section class="box-border caret-transparent pt-5 md:pt-0">
        <div class="box-border caret-transparent max-w-[1540px] mx-auto px-[15px] md:px-[30px]">
          <div class="text-white text-center mb-10">
            <h1 class="text-4xl font-bold mb-4 md:text-5xl">Construction Company in Ayrshire</h1>
            <p class="text-lg md:text-xl max-w-3xl mx-auto">
              As a professional construction company in Ayrshire, Ayrshire Fencing Group provides comprehensive building and installation services for outdoor structures including fencing, decking, gates, sheds, and garden rooms.
            </p>
          </div>
          <div class="text-white mb-8">
            <h2 class="text-2xl font-bold mb-4 md:text-3xl md:mb-6">Construction Company Services</h2>
            <p class="text-lg md:text-xl mb-6 md:mb-8">
              Our construction company in Ayrshire specializes in outdoor construction projects. As a trusted construction company, we are fully qualified and insured, with over 13 years of experience delivering quality construction services throughout Ayrshire and Glasgow.
            </p>

            <h3 class="text-xl font-bold mb-3 md:text-2xl md:mb-4">Repairs and Maintenance</h3>
            <p class="text-base md:text-lg mb-4 md:mb-6">
              Repairs and maintenance keep everything working properly. We do regular maintenance on fences, decks, and other structures we've built. Repairs and maintenance in Ayrshire means dealing with weather damage, wear and tear, and just keeping things in good condition. Our maintenance services ensure your outdoor structures remain safe, functional, and attractive for years to come. <a href="/service/repairs-and-maintenance-irvine" class="text-[#787e59] hover:underline font-medium">Learn about repairs and maintenance</a>.
            </p>
          </div>
        </div>
      </section>
      <ServicesSection client:load />
      <WhyChooseSection client:load />
      <FAQSection client:load />
      <CTASection client:load />
      <Footer client:load />
    </div>
</BaseLayout>


